<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>sistem-market</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ===================== FILTROS ===================== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.sistemmarket.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/dashboard</url-pattern>
        <url-pattern>/productos</url-pattern>
        <url-pattern>/usuarios</url-pattern>
        <url-pattern>/carrito</url-pattern>
        <url-pattern>/catalogo</url-pattern>
        <url-pattern>/pedidos</url-pattern>
        <url-pattern>/ConfirmarCompraServlet</url-pattern>
        <url-pattern>/ActualizarPedidoServlet</url-pattern>
        <url-pattern>/logout</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.sistemmarket.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/productos</url-pattern>
        <url-pattern>/usuarios</url-pattern>
        <url-pattern>/ActualizarPedidoServlet</url-pattern>
    </filter-mapping>

    <!-- ===================== SERVLETS ===================== -->
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>com.sistemmarket.controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>com.sistemmarket.controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardController</servlet-name>
        <servlet-class>com.sistemmarket.controller.DashboardController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardController</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProductoController</servlet-name>
        <servlet-class>com.sistemmarket.controller.ProductoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductoController</servlet-name>
        <url-pattern>/productos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UsuarioController</servlet-name>
        <servlet-class>com.sistemmarket.controller.UsuarioController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsuarioController</servlet-name>
        <url-pattern>/usuarios</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CarritoController</servlet-name>
        <servlet-class>com.sistemmarket.controller.CarritoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CarritoController</servlet-name>
        <url-pattern>/carrito</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>CatalogoController</servlet-name>
        <servlet-class>com.sistemmarket.controller.CatalogoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CatalogoController</servlet-name>
        <url-pattern>/catalogo</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>PedidoController</servlet-name>
        <servlet-class>com.sistemmarket.controller.PedidoController</servlet-class>
    </servlet>
    <servlet-mapping>   
        <servlet-name>PedidoController</servlet-name>
        <url-pattern>/pedidos</url-pattern>
    </servlet-mapping>
    
    <!-- ConfirmarCompraServlet: cualquier usuario logueado -->
    <servlet>
        <servlet-name>ConfirmarCompraServlet</servlet-name>
        <servlet-class>com.sistemmarket.controller.ConfirmarCompraServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConfirmarCompraServlet</servlet-name>
        <url-pattern>/ConfirmarCompraServlet</url-pattern>
    </servlet-mapping>

    <!-- ActualizarPedidoServlet: solo ADMIN -->
    <servlet>
        <servlet-name>ActualizarPedidoServlet</servlet-name>
        <servlet-class>com.sistemmarket.controller.ActualizarPedidoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ActualizarPedidoServlet</servlet-name>
        <url-pattern>/ActualizarPedidoServlet</url-pattern>
    </servlet-mapping>
    
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
